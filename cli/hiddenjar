#!/usr/bin/env bash
#
# hiddenjar — build a custom android.jar (with hidden/internal APIs) from an
# Android emulator or device, then optionally install it into the SDK.
#
# See docs/BUILD_CUSTOM_ANDROID_JAR_FROM_EMULATOR.md
#
# Compatible with macOS bash 3.2 (no associative arrays / mapfile).

set -euo pipefail

# ----------------------------------------------------------------------------
# Constants & globals
# ----------------------------------------------------------------------------
VERSION="1.0.0"
DEX_TOOLS_VERSION="2.4.37"
DEX_TOOLS_URL="https://github.com/ThexXTURBOXx/dex2jar/releases/download/${DEX_TOOLS_VERSION}/dex-tools-${DEX_TOOLS_VERSION}.zip"
CACHE_DIR="${HOME}/.cache/hiddenjar"
MIN_JAR_BYTES=1024   # jars smaller than this are almost certainly stripped shells

# Directory of this script — used to locate the bundled Stubifier.java.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STUBIFIER_SRC="${SCRIPT_DIR}/Stubifier.java"
CLOSURE_SRC="${SCRIPT_DIR}/ClosureVerify.java"

# Options (set by parse_args)
OPT_SERIAL=""
OPT_AVD=""
OPT_API=""
OPT_SDK_DIR=""
OPT_ONLY_FRAMEWORK="false"
OPT_OUTPUT=""
OPT_INSTALL="false"
OPT_DEX_TOOLS=""
OPT_WORK_DIR=""
OPT_KEEP="false"
OPT_KEEP_BODIES="false"

ADB=""
D2J=""
WORK_DIR=""
WORK_DIR_IS_TEMP="false"

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
_c_reset=""; _c_red=""; _c_yel=""; _c_grn=""; _c_dim=""
if [ -t 2 ]; then
  _c_reset="\033[0m"; _c_red="\033[31m"; _c_yel="\033[33m"; _c_grn="\033[32m"; _c_dim="\033[2m"
fi
log()  { printf "%b[hiddenjar]%b %s\n" "$_c_grn" "$_c_reset" "$*" >&2; }
info() { printf "%b[hiddenjar]%b %s\n" "$_c_dim" "$_c_reset" "$*" >&2; }
warn() { printf "%b[hiddenjar] WARN:%b %s\n" "$_c_yel" "$_c_reset" "$*" >&2; }
die()  { printf "%b[hiddenjar] ERROR:%b %s\n" "$_c_red" "$_c_reset" "$*" >&2; exit 1; }

cleanup() {
  if [ "$WORK_DIR_IS_TEMP" = "true" ] && [ "$OPT_KEEP" != "true" ] && [ -n "$WORK_DIR" ] && [ -d "$WORK_DIR" ]; then
    rm -rf "$WORK_DIR"
  elif [ -n "$WORK_DIR" ] && [ -d "$WORK_DIR" ]; then
    info "Work dir kept at: $WORK_DIR"
  fi
}
trap cleanup EXIT

# ----------------------------------------------------------------------------
# Helpers
# ----------------------------------------------------------------------------
usage() {
  cat >&2 <<EOF
hiddenjar v${VERSION} — build a custom android.jar with hidden APIs from an emulator/device

USAGE:
  hiddenjar build   [options]
  hiddenjar restore [--api N] [--sdk-dir DIR]
  hiddenjar doctor
  hiddenjar help

BUILD OPTIONS:
  --serial ID          adb device serial (default: auto — a running emulator, else first device)
  --avd NAME           if no device is running, boot this AVD headless first
  --api N              API level override (default: read from device)
  --sdk-dir DIR        Android SDK root (default: \$ANDROID_HOME / \$ANDROID_SDK_ROOT / ~/Library/Android/sdk)
  --only-framework     merge only /system/framework/framework.jar (fast, incomplete)
  --all-bootclasspath  merge hidden-API namespaces (android.*, com.android.internal.*, dalvik.*)
                       from every \$BOOTCLASSPATH jar that has DEX (default; full coverage)
  --output FILE        output path (default: ./android-<api>-custom.jar)
  --install            install into <sdk>/platforms/android-<api>*/android.jar (auto-backup .orig)
  --dex-tools DIR      path to an unpacked dex-tools distribution (default: auto-download + cache)
  --work-dir DIR       scratch dir (default: mktemp; kept on failure)
  --keep               keep the work dir even on success
  --keep-bodies        keep real dex2jar method bodies instead of stripping them to signature-only
                       stubs. Bodies let you browse decompiled sources, but Gradle lint / unit tests
                       (MockableJarTransform) then FAIL on the jar. Default: strip to stubs.

EXAMPLES:
  hiddenjar doctor
  hiddenjar build --only-framework
  hiddenjar build --avd Pixel_10_API_37 --install
  hiddenjar restore --api 37
EOF
}

have() { command -v "$1" >/dev/null 2>&1; }

resolve_sdk_dir() {
  if [ -n "$OPT_SDK_DIR" ]; then echo "$OPT_SDK_DIR"; return; fi
  if [ -n "${ANDROID_HOME:-}" ]; then echo "$ANDROID_HOME"; return; fi
  if [ -n "${ANDROID_SDK_ROOT:-}" ]; then echo "$ANDROID_SDK_ROOT"; return; fi
  echo "${HOME}/Library/Android/sdk"
}

resolve_adb() {
  local sdk; sdk="$(resolve_sdk_dir)"
  if [ -x "${sdk}/platform-tools/adb" ]; then ADB="${sdk}/platform-tools/adb"; return; fi
  if have adb; then ADB="$(command -v adb)"; return; fi
  die "adb not found (looked in ${sdk}/platform-tools and PATH)"
}

# Resolve the platform dir for an API level: tries android-N, android-N.0, then
# any android-N* whose source.properties reports AndroidVersion.ApiLevel=N.
resolve_platform_dir() {
  local sdk="$1" api="$2" d
  for d in "${sdk}/platforms/android-${api}" "${sdk}/platforms/android-${api}.0"; do
    if [ -f "${d}/android.jar" ]; then echo "$d"; return 0; fi
  done
  for d in "${sdk}/platforms/android-${api}"*; do
    [ -f "${d}/android.jar" ] || continue
    if [ -f "${d}/source.properties" ] && grep -q "AndroidVersion.ApiLevel=${api}\$" "${d}/source.properties"; then
      echo "$d"; return 0
    fi
  done
  return 1
}

ensure_dex_tools() {
  # Explicit path wins.
  if [ -n "$OPT_DEX_TOOLS" ]; then
    D2J="$(find "$OPT_DEX_TOOLS" -name d2j-dex2jar.sh -type f 2>/dev/null | head -1 || true)"
    [ -n "$D2J" ] || die "--dex-tools '$OPT_DEX_TOOLS' has no d2j-dex2jar.sh"
    chmod +x "$(dirname "$D2J")"/*.sh 2>/dev/null || true
    return
  fi
  # Cached?
  D2J="$(find "$CACHE_DIR" -name d2j-dex2jar.sh -type f 2>/dev/null | head -1 || true)"
  if [ -n "$D2J" ]; then chmod +x "$(dirname "$D2J")"/*.sh 2>/dev/null || true; return; fi
  # Download.
  have curl || die "dex-tools not cached and curl is unavailable; pass --dex-tools DIR"
  have unzip || die "unzip is required"
  mkdir -p "$CACHE_DIR"
  log "Downloading dex-tools ${DEX_TOOLS_VERSION} ..."
  curl -fsSL -o "${CACHE_DIR}/dex-tools.zip" "$DEX_TOOLS_URL" || die "failed to download dex-tools"
  unzip -q -o "${CACHE_DIR}/dex-tools.zip" -d "$CACHE_DIR"
  D2J="$(find "$CACHE_DIR" -name d2j-dex2jar.sh -type f 2>/dev/null | head -1 || true)"
  [ -n "$D2J" ] || die "dex-tools download did not contain d2j-dex2jar.sh"
  chmod +x "$(dirname "$D2J")"/*.sh 2>/dev/null || true
}

# ----------------------------------------------------------------------------
# Device selection
# ----------------------------------------------------------------------------
list_devices() { "$ADB" devices | awk 'NR>1 && $2=="device" {print $1}'; }

boot_avd_if_needed() {
  [ -n "$OPT_AVD" ] || return 0
  local sdk emu
  sdk="$(resolve_sdk_dir)"
  emu="${sdk}/emulator/emulator"
  [ -x "$emu" ] || die "emulator binary not found at $emu"
  log "Booting AVD '$OPT_AVD' headless ..."
  "$emu" -avd "$OPT_AVD" -no-window -no-audio -no-boot-anim -no-snapshot >/dev/null 2>&1 &
  # Wait for a device to appear and finish booting.
  local tries=0
  while [ "$(list_devices | wc -l | tr -d ' ')" = "0" ] && [ $tries -lt 60 ]; do
    sleep 2; tries=$((tries+1))
  done
  OPT_SERIAL="$(list_devices | grep '^emulator-' | head -1 || true)"
  [ -n "$OPT_SERIAL" ] || OPT_SERIAL="$(list_devices | head -1 || true)"
  [ -n "$OPT_SERIAL" ] || die "AVD did not come online"
  "$ADB" -s "$OPT_SERIAL" wait-for-device
  log "Waiting for boot to complete ..."
  tries=0
  while [ "$("$ADB" -s "$OPT_SERIAL" shell getprop sys.boot_completed 2>/dev/null | tr -d '\r ')" != "1" ] && [ $tries -lt 90 ]; do
    sleep 2; tries=$((tries+1))
  done
}

pick_serial() {
  if [ -n "$OPT_SERIAL" ]; then return; fi
  boot_avd_if_needed
  if [ -n "$OPT_SERIAL" ]; then return; fi
  local emu first
  emu="$(list_devices | grep '^emulator-' | head -1 || true)"
  first="$(list_devices | head -1 || true)"
  if [ -n "$emu" ]; then OPT_SERIAL="$emu"
  elif [ -n "$first" ]; then OPT_SERIAL="$first"
  else die "no adb device online — start an emulator or pass --avd NAME"; fi
}

# Strip every .class under a directory to a signature-only stub, in place.
#
# hiddenjar overlays real dex2jar-decompiled framework bodies onto android.jar. Those bodies carry
# try/catch blocks, and Gradle's MockableJarGenerator (lint + unit tests) crashes on them
# (NPE "Cannot read field outgoingEdges ... handlerRangeBlock is null", issue #46). Reducing the
# classes to stubs — exactly the shape the SDK's own android.jar ships — makes the transform pass.
# javac only reads signatures, so compilation of hidden/internal APIs is unaffected.
stubify_dir() {
  local dir="$1"
  local lib cp stubout
  lib="$(dirname "$D2J")/lib"
  cp="$(find "$lib" -name '*.jar' 2>/dev/null | tr '\n' ':')"
  [ -n "$cp" ] || die "dex-tools lib (ASM) not found under $lib; cannot strip method bodies (pass --keep-bodies to skip)"
  [ -f "$STUBIFIER_SRC" ] || die "Stubifier.java not found at $STUBIFIER_SRC — keep the cli/ directory intact, or pass --keep-bodies"
  stubout="${WORK_DIR}/stubifier-out"
  mkdir -p "$stubout"
  log "Stripping method bodies to signature-only stubs (fixes Gradle MockableJarTransform) ..."
  javac -cp "$cp" -d "$stubout" "$STUBIFIER_SRC" || die "failed to compile Stubifier.java"
  java -cp "${stubout}:${cp}" Stubifier "$dir" || die "stubify pass failed"
}

# ----------------------------------------------------------------------------
# build
# ----------------------------------------------------------------------------
cmd_build() {
  resolve_adb
  ensure_dex_tools
  have javac || die "javac not found (install a JDK)"
  have jar   || die "jar not found (install a JDK)"
  have unzip || die "unzip is required"

  pick_serial
  log "Target device: $OPT_SERIAL"

  local api
  api="${OPT_API:-$("$ADB" -s "$OPT_SERIAL" shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r ')}"
  [ -n "$api" ] || die "could not read API level from device"
  log "API level: $api"

  local sdk platform_dir base_jar
  sdk="$(resolve_sdk_dir)"
  if ! platform_dir="$(resolve_platform_dir "$sdk" "$api")"; then
    warn "No SDK platform for API $api. Installed platforms:"
    ls "${sdk}/platforms" >&2 2>/dev/null || true
    die "install it via sdkmanager \"platforms;android-${api}\" or pass --sdk-dir"
  fi
  base_jar="${platform_dir}/android.jar"
  log "SDK base android.jar: $base_jar"

  # Work dir
  if [ -n "$OPT_WORK_DIR" ]; then
    WORK_DIR="$OPT_WORK_DIR"; mkdir -p "$WORK_DIR"
  else
    WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/hiddenjar.XXXXXX")"; WORK_DIR_IS_TEMP="true"
  fi
  local pulled="${WORK_DIR}/pulled" classes="${WORK_DIR}/classes" merged="${WORK_DIR}/merged"
  mkdir -p "$pulled" "$classes" "$merged"

  # Determine the jar list to pull.
  local jar_list=""
  if [ "$OPT_ONLY_FRAMEWORK" = "true" ]; then
    jar_list="/system/framework/framework.jar"
  else
    jar_list="$("$ADB" -s "$OPT_SERIAL" shell 'echo $BOOTCLASSPATH' 2>/dev/null | tr -d '\r' | tr ':' '\n' | sed '/^$/d')"
  fi
  local total_jars; total_jars="$(printf "%s\n" "$jar_list" | sed '/^$/d' | wc -l | tr -d ' ')"
  log "Boot classpath entries to consider: $total_jars"

  # Pull + validate + convert.
  local converted=0 skipped=0 failed=0 idx=0
  local dev_path local_name local_jar dexcount out_jar
  while IFS= read -r dev_path; do
    [ -n "$dev_path" ] || continue
    idx=$((idx+1))
    local_name="$(printf "%s" "$dev_path" | sed 's#^/##; s#/#_#g')"
    local_jar="${pulled}/${local_name}"
    if ! "$ADB" -s "$OPT_SERIAL" pull "$dev_path" "$local_jar" >/dev/null 2>&1; then
      warn "[$idx/$total_jars] pull failed: $dev_path"; failed=$((failed+1)); continue
    fi
    # Validate: reasonable size AND contains classes*.dex
    local size; size="$(wc -c < "$local_jar" | tr -d ' ')"
    dexcount="$(unzip -l "$local_jar" 2>/dev/null | grep -cE 'classes[0-9]*\.dex' || true)"
    if [ "$size" -lt "$MIN_JAR_BYTES" ] || [ "$dexcount" = "0" ]; then
      info "[$idx/$total_jars] skip (stripped/no DEX, ${size}B): $dev_path"; skipped=$((skipped+1)); continue
    fi
    out_jar="${classes}/${local_name%.jar}-classes.jar"
    if "$D2J" --force -o "$out_jar" "$local_jar" >/dev/null 2>&1 && [ -f "$out_jar" ]; then
      info "[$idx/$total_jars] converted ($dexcount dex): $dev_path"; converted=$((converted+1))
    else
      warn "[$idx/$total_jars] dex2jar failed: $dev_path"; failed=$((failed+1))
    fi
  done <<EOF
$jar_list
EOF

  log "Jars converted: $converted, skipped: $skipped, failed: $failed"
  [ "$converted" -gt 0 ] || die "no framework jars had usable DEX — use an API >= 34 image or a device"

  # Merge: SDK android.jar first (base = the curated public API surface), then overlay the
  # device's real framework bytecode on top so @hide members and com.android.internal appear.
  #
  # Filter the overlay by NAMESPACE, not by source jar. The boot classpath also carries the full
  # ART runtime (java/*, sun/*, jdk/*, javax/*, libcore/*) and repackaged libraries
  # (com.android.okhttp, com.android.org.bouncycastle, org.apache.xml*, gov.nist, ...). None of
  # those belong on the compile classpath; overlaying them shadows the JDK and the app's own
  # dependencies, so Kotlin/Gradle then reject the jar ("Cannot access <X> which is a supertype
  # ... missing or conflicting dependencies", issue #100). We keep only what the SDK is meant to
  # expose: android.* (public + @hide — much of it now ships from APEX modules like framework-wifi,
  # not just framework.jar), plus com.android.internal.* and dalvik.* (e.g. @hide
  # dalvik.system.VMRuntime). Everything else stays out; the base jar already provides the curated
  # java.*/javax.*/org.*/dalvik.* public stubs.
  log "Merging into custom android.jar (overlay filtered to hidden-API namespaces) ..."
  ( cd "$merged" && unzip -q -o "$base_jar" )
  local -a overlay_ns=( 'android/*' 'com/android/internal/*' 'dalvik/*' )
  local cj rc
  for cj in "${classes}"/*-classes.jar; do
    [ -f "$cj" ] || continue
    rc=0
    ( cd "$merged" && unzip -q -o "$cj" "${overlay_ns[@]}" ) || rc=$?
    # unzip rc 11 = this jar held none of the allowlisted namespaces (e.g. a pure-runtime jar);
    # that is expected and intentional. Any other non-zero code is a real extraction error.
    [ "$rc" -eq 0 ] || [ "$rc" -eq 11 ] || warn "overlay failed (unzip rc=$rc): $(basename "$cj")"
  done
  rm -rf "${merged}/META-INF"

  # Strip real method bodies to stubs (default) so Gradle's MockableJarTransform accepts the jar.
  if [ "$OPT_KEEP_BODIES" = "true" ]; then
    warn "--keep-bodies: keeping real method bodies; Gradle lint/unit tests (MockableJarTransform) will FAIL on this jar"
  else
    stubify_dir "$merged"
  fi

  # Output path
  local output="${OPT_OUTPUT:-$(pwd)/android-${api}-custom.jar}"
  ( cd "$merged" && jar cf "$output" . ) || die "jar packaging failed"
  local outsize; outsize="$(wc -c < "$output" | tr -d ' ')"
  local internal; internal="$(unzip -l "$output" 2>/dev/null | grep -c 'com/android/internal/' || true)"
  local allclasses; allclasses="$(unzip -l "$output" 2>/dev/null | grep -c '\.class$' || true)"
  log "Built: $output (${outsize} bytes, ${allclasses} classes, ${internal} com.android.internal)"

  # Verify: prove the jar is actually usable before we let it near an SDK (the real success gate).
  verify_compile "$output" "$base_jar" || die "verification failed (see checks above)"

  # Install
  if [ "$OPT_INSTALL" = "true" ]; then
    install_jar "$output" "$platform_dir"
  fi

  log "Done."
}

# The success gate. A jar that "builds" is worthless if the toolchain later rejects it, so we run
# four independent checks — each catches a failure mode the others miss (issue #100 slipped past the
# old one-probe gate because that probe only touched three @hide symbols and never a normal class):
#   1. compile probe  — hidden AND normal public API + supertype chains resolve under javac
#   2. conflict guard  — the jar does NOT ship JDK/dependency-shadowing runtime (the issue-#100 cause)
#   3. public-API floor — the merge never dropped the SDK's own classes
#   4. supertype closure — no public class is left with a missing/dangling supertype
verify_compile() {
  local jar="$1" base="$2"
  local probe="${WORK_DIR}/probe"
  mkdir -p "$probe"
  local ok=0

  # (1) Compile probe: normal public API + supertype chains (View→Drawable.Callback, Activity, ...)
  #     AND @hide symbols across android.*, dalvik.* and com.android.internal.*. If any of these
  #     types or the supertype graph they touch is missing/corrupt, javac fails here.
  cat > "${probe}/HiddenApiProbe.java" <<'JAVA'
import android.app.Activity;
import android.app.ActivityThread;
import android.content.Context;
import android.graphics.drawable.Drawable;
import android.os.Bundle;
import android.os.IBinder;
import android.os.ServiceManager;
import android.view.View;
import android.view.ViewGroup;
import dalvik.system.VMRuntime;

public abstract class HiddenApiProbe extends ViewGroup {   // walks View → Drawable.Callback, KeyEvent.Callback, ...
    public HiddenApiProbe(Context c) { super(c); }
    Drawable.Callback asDrawableCallback() { return this; } // View implements Drawable.Callback (issue #100 supertype)
    Activity activity;
    Bundle bundle;
    View view;
    IBinder windowService() { return ServiceManager.getService("window"); } // @hide android.os
    ActivityThread currentThread() { return ActivityThread.currentActivityThread(); } // @hide android.app
    Object vmRuntime() { return VMRuntime.getRuntime(); } // @hide dalvik.system (absent from stock)
    Class<?> internal() { return com.android.internal.R.class; } // com.android.internal
}
JAVA
  if javac -nowarn -cp "$jar" -d "${probe}/out" "${probe}/HiddenApiProbe.java" 2>"${probe}/javac.log"; then
    info "verify(1/4) compile probe OK — View/ViewGroup/Drawable.Callback/Activity + @hide resolve"
  else
    warn "verify(1/4) compile probe FAILED — the jar cannot resolve core public + hidden APIs:"
    cat "${probe}/javac.log" >&2 || true
    ok=1
  fi

  # (2) Conflict guard: the jar must NOT ship the ART runtime / repackaged libs that shadow the JDK
  #     and the app's own dependencies. Their presence is what made Kotlin/Gradle reject the jar in
  #     issue #100, and it guards the overlay namespace filter against regressing.
  local polluted
  polluted="$(unzip -l "$jar" 2>/dev/null | awk '{print $NF}' \
    | grep -oE '^(sun|jdk|libcore|com/google|com/android/okhttp|com/android/org|gov/nist|org/apache/(xml|xpath|xalan))/' \
    | sort -u | tr '\n' ' ')"
  if [ -n "$polluted" ]; then
    warn "verify(2/4) conflict guard FAILED — jar ships JDK/dependency-shadowing namespaces: ${polluted}"
    ok=1
  else
    info "verify(2/4) conflict guard OK — no JDK/dependency-shadowing namespaces"
  fi

  # (3) Public-API floor: the merge overlays onto the SDK jar, so the result must never contain
  #     FEWER classes than the base SDK jar. Fewer means the merge lost curated public API.
  local base_n out_n
  base_n="$(unzip -l "$base" 2>/dev/null | grep -c '\.class$' || true)"
  out_n="$(unzip -l "$jar" 2>/dev/null | grep -c '\.class$' || true)"
  if [ "$out_n" -lt "$base_n" ]; then
    warn "verify(3/4) public-API floor FAILED — jar has ${out_n} classes but base SDK jar has ${base_n}"
    ok=1
  else
    info "verify(3/4) public-API floor OK — ${out_n} classes (>= ${base_n} in base SDK jar)"
  fi

  # (4) Supertype closure: no android.*/dalvik.*/java.* class may be left with a dangling supertype
  #     (the exact issue-#100 symptom, e.g. View losing Drawable.Callback). Uses ASM from dex-tools.
  if closure_verify "$jar"; then
    info "verify(4/4) supertype closure OK"
  else
    warn "verify(4/4) supertype closure FAILED — a public supertype is missing (issue #100 symptom)"
    ok=1
  fi

  [ "$ok" = "0" ] && log "Verification OK: all 4 checks passed" || warn "Verification FAILED (see checks above)"
  return "$ok"
}

# Compiles + runs the bundled ClosureVerify against the jar. Returns non-zero only on a HARD failure
# (a missing public supertype); a missing tool/ASM is reported and treated as a skip (returns 0) so
# the gate never blocks a build just because the checker itself could not run.
closure_verify() {
  local jar="$1" lib cp out
  lib="$(dirname "$D2J")/lib"
  cp="$(find "$lib" -name '*.jar' 2>/dev/null | tr '\n' ':')"
  if [ -z "$cp" ] || [ ! -f "$CLOSURE_SRC" ]; then
    warn "closure check skipped (ASM lib or ClosureVerify.java not found)"; return 0
  fi
  out="${WORK_DIR}/closure-out"; mkdir -p "$out"
  if ! javac -cp "$cp" -d "$out" "$CLOSURE_SRC" 2>/dev/null; then
    warn "closure check skipped (could not compile ClosureVerify.java)"; return 0
  fi
  java -cp "${out}:${cp}" ClosureVerify "$jar"
}

install_jar() {
  local built="$1" platform_dir="$2"
  local target="${platform_dir}/android.jar"
  local backup="${platform_dir}/android.jar.orig"
  if [ ! -f "$backup" ]; then
    cp "$target" "$backup"
    log "Backed up original SDK jar -> $backup"
  else
    info "Backup already exists (kept): $backup"
  fi
  cp "$built" "$target"
  log "Installed custom jar -> $target"
  log "Restore anytime with: hiddenjar restore --api <level>"
}

# ----------------------------------------------------------------------------
# restore
# ----------------------------------------------------------------------------
cmd_restore() {
  local sdk platform_dir api="$OPT_API"
  sdk="$(resolve_sdk_dir)"
  [ -n "$api" ] || die "restore requires --api N"
  platform_dir="$(resolve_platform_dir "$sdk" "$api")" || die "no SDK platform for API $api"
  local target="${platform_dir}/android.jar" backup="${platform_dir}/android.jar.orig"
  [ -f "$backup" ] || die "no backup found at $backup"
  cp "$backup" "$target"
  log "Restored original SDK android.jar for API $api"
}

# ----------------------------------------------------------------------------
# doctor
# ----------------------------------------------------------------------------
cmd_doctor() {
  local ok=0
  resolve_adb && printf "  adb:      %s\n" "$ADB" >&2 || ok=1
  if have javac; then printf "  javac:    %s\n" "$(command -v javac)" >&2; else printf "  javac:    MISSING\n" >&2; ok=1; fi
  if have jar;   then printf "  jar:      %s\n" "$(command -v jar)" >&2;   else printf "  jar:      MISSING\n" >&2; ok=1; fi
  if have unzip; then printf "  unzip:    %s\n" "$(command -v unzip)" >&2; else printf "  unzip:    MISSING\n" >&2; ok=1; fi
  if have zip;   then printf "  zip:      %s\n" "$(command -v zip)" >&2;   else printf "  zip:      (optional, not found)\n" >&2; fi
  if ensure_dex_tools 2>/dev/null; then printf "  dex2jar:  %s\n" "$D2J" >&2; else printf "  dex2jar:  MISSING (will auto-download on build)\n" >&2; fi
  printf "  sdk-dir:  %s\n" "$(resolve_sdk_dir)" >&2
  if [ -n "$ADB" ]; then
    printf "  devices:\n" >&2
    "$ADB" devices | awk 'NR>1 && NF' | sed 's/^/    /' >&2 || true
  fi
  [ "$ok" = "0" ] && log "doctor: all required tools present" || warn "doctor: some tools missing (see above)"
  return "$ok"
}

# ----------------------------------------------------------------------------
# Argument parsing
# ----------------------------------------------------------------------------
parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --serial) OPT_SERIAL="$2"; shift 2;;
      --avd) OPT_AVD="$2"; shift 2;;
      --api) OPT_API="$2"; shift 2;;
      --sdk-dir) OPT_SDK_DIR="$2"; shift 2;;
      --only-framework) OPT_ONLY_FRAMEWORK="true"; shift;;
      --all-bootclasspath) OPT_ONLY_FRAMEWORK="false"; shift;;
      --output) OPT_OUTPUT="$2"; shift 2;;
      --install) OPT_INSTALL="true"; shift;;
      --dex-tools) OPT_DEX_TOOLS="$2"; shift 2;;
      --work-dir) OPT_WORK_DIR="$2"; shift 2;;
      --keep) OPT_KEEP="true"; shift;;
      --keep-bodies) OPT_KEEP_BODIES="true"; shift;;
      -h|--help) usage; exit 0;;
      *) die "unknown option: $1";;
    esac
  done
}

main() {
  local sub="${1:-help}"; shift || true
  case "$sub" in
    build)   parse_args "$@"; cmd_build;;
    restore) parse_args "$@"; cmd_restore;;
    doctor)  parse_args "$@"; cmd_doctor;;
    help|-h|--help) usage;;
    *) usage; die "unknown command: $sub";;
  esac
}

main "$@"
